#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const yargs = require('yargs');

const { createStack } = require('../dist/createStack');
const { deleteStack } = require('../dist/deleteStack');
const { listStacks } = require('../dist/listStacks');
const { previewStack } = require('../dist/previewStack');
const { redeployStack } = require('../dist/redeployStack');
const { updateStack } = require('../dist/updateStack');
const { getOutputConfig, setOutputConfig } = require('../dist/lib/output');

const pkg = JSON.parse(fs.readFileSync(path.resolve(__dirname, '../package.json'), 'utf8'));
const isCI = process.env.CI === 'true' || process.env.GITHUB_ACTIONS === 'true';

const FILE_FLAGS = ['--template', '--params', '-t', '-p'];

function completeFile(current) {
  const dir = path.dirname(current) || '.';
  const prefix = path.basename(current);
  try {
    const fullDir = path.resolve(process.cwd(), dir);
    const files = fs.readdirSync(fullDir);
    return files
      .filter((f) => f.startsWith(prefix))
      .map((f) => {
        const joined = path.join(dir === '.' ? '' : dir, f);
        try {
          const stat = fs.statSync(path.resolve(process.cwd(), joined));
          return stat.isDirectory() ? joined + path.sep : joined;
        } catch {
          return joined;
        }
      });
  } catch {
    return [];
  }
}

function isCompletingFileValue() {
  const argv = process.argv;
  const prev = argv[argv.length - 2];
  return typeof prev === 'string' && FILE_FLAGS.includes(prev);
}

function logError(msg) {
  console.log(`\x1b[31mError: ${msg}\x1b[0m`);
}

function logErrorDetails(data) {
  if (data) {
    console.log('\nError details:');
    console.log(JSON.stringify(data, null, 2));
  }
}

function clarifyAwsError(msg) {
  if (/region\s+is\s+missing|configuration.*region|Missing required key 'region'/i.test(msg)) {
    return 'AWS region is not set. Set AWS_REGION or AWS_DEFAULT_REGION, or run `aws configure` (or `aws configure sso` if your org uses SSO).';
  }
  if (/credentials|Unable to locate credentials|Token is expired/i.test(msg)) {
    return 'AWS credentials not found or expired. Set AWS_PROFILE, AWS_ACCESS_KEY_ID/secret, or run `aws configure` (or `aws configure sso` if your org uses SSO).';
  }
  return msg;
}

async function runCommand(fn) {
  try {
    await fn();
  } catch (err) {
    const message = clarifyAwsError(err.message);
    logError(message);
    if (message !== err.message) {
      console.log(`\x1b[90m(original: ${err.message})\x1b[0m`);
    }
    if (getOutputConfig().verbose) {
      logErrorDetails(err.data);
    }
    process.exit(1);
  }
}

const nameOpt = {
  name: { type: 'string', alias: 'n', describe: 'Stack name', demandOption: true },
};
const templateOpt = {
  template: { type: 'string', alias: 't', describe: 'CloudFormation template file', demandOption: true },
};
const paramsOpt = {
  params: { type: 'string', alias: 'p', describe: 'Parameters file (YAML). Optional; omit to use template defaults.', demandOption: false },
};
const createIfMissingOpt = {
  // Preferred flag name.
  create: {
    type: 'boolean',
    describe: 'Create the stack if it does not exist (update-stack only)',
    demandOption: false,
    default: false,
  },
  // Backwards-compatible alias.
  createIfMissing: {
    type: 'boolean',
    alias: 'm',
    describe: 'Alias for --create (create the stack if it does not exist)',
    demandOption: false,
    default: false,
  },
};
const confirmOpt = {
  confirm: { type: 'string', alias: 'c', describe: 'Repeat stack name to confirm deletion', demandOption: true },
};

yargs
  .option('ci', {
    type: 'boolean',
    alias: 'C',
    description: 'CI mode (compact output). Auto-detected when CI=true or GITHUB_ACTIONS=true. Colors remain enabled in CI.',
    default: isCI,
  })
  .option('no-color', {
    type: 'boolean',
    alias: 'N',
    description: 'Disable colored output',
    default: false,
  })
  .option('verbose', {
    type: 'boolean',
    alias: 'V',
    description: 'Show full error details (e.g. err.data JSON) on failure',
    default: false,
  })
  .middleware((argv) => {
    setOutputConfig({
      ci: argv.ci,
      color: !argv.noColor && (process.stdout.isTTY || argv.ci),
      verbose: argv.verbose,
    });
  })
  .command(
    'list-stacks',
    'List all CloudFormation stacks',
    (cmd) => cmd,
    () => {
      runCommand(() => listStacks());
    }
  )
  .command(
    'create-stack',
    'Create a CloudFormation stack',
    (cmd) => cmd.options({ ...nameOpt, ...templateOpt, ...paramsOpt }),
    ({ name, template, params }) => {
      runCommand(() => createStack(name, template, params));
    }
  )
  .command(
    'delete-stack',
    'Delete a CloudFormation stack',
    (cmd) => cmd.options({ ...nameOpt, ...confirmOpt }),
    ({ name, confirm }) => {
      runCommand(() => deleteStack(name, confirm));
    }
  )
  .command(
    'redeploy-stack',
    'Redeploy a CloudFormation stack (uses existing params)',
    (cmd) => cmd.options({ ...nameOpt, ...templateOpt }),
    ({ name, template }) => {
      runCommand(() => redeployStack(name, template));
    }
  )
  .command(
    'update-stack',
    'Update a CloudFormation stack',
    (cmd) => cmd.options({ ...nameOpt, ...templateOpt, ...paramsOpt, ...createIfMissingOpt }),
    ({ name, template, params, create, createIfMissing }) => {
      runCommand(() => updateStack(name, template, params, Boolean(create || createIfMissing)));
    }
  )
  .command(
    'preview-stack',
    'Preview changes without deploying (change set only)',
    (cmd) => cmd.options({ ...nameOpt, ...templateOpt, ...paramsOpt }),
    ({ name, template, params }) => {
      runCommand(() => previewStack(name, template, params));
    }
  )
  .completion(
    'completion',
    'Generate shell completion script',
    (current, argv, defaultCompletion, done) => {
      if (isCompletingFileValue()) {
        return done(completeFile(current || ''));
      }
      defaultCompletion();
    }
  )
  .demandCommand(1)
  .fail((msg, err, yargs) => {
    if (msg) {
      logError(msg);
      console.log('\n' + yargs.help());
    }
    process.exit(1);
  })
  .strict()
  .help()
  .alias('h', 'help')
  .version(pkg.version)
  .alias('v', 'version')
  .argv;
