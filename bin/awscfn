#!/usr/bin/env node

const yargs = require('yargs');
const fs = require('fs');
const path = require('path');

const { createStack } = require('../dist/createStack');
const { deleteStack } = require('../dist/deleteStack');
const { redeployStack } = require('../dist/redeployStack');
const { updateStack } = require('../dist/updateStack');
const { setOutputConfig } = require('../dist/lib/output');

const log = console.log;
const errorLog = (msg) => log(`\x1b[31mError: ${msg}\x1b[0m`);

// Read version from package.json
const packageJsonPath = path.resolve(__dirname, '../package.json');
const packageJson = JSON.parse(fs.readFileSync(packageJsonPath, 'utf8'));
const version = packageJson.version;

// Detect CI environment
const isCI = process.env.CI === 'true' || process.env.GITHUB_ACTIONS === 'true';

const FILE_FLAGS = ['--template', '--params', '-t', '-p'];

function completeFile(current) {
  const dir = path.dirname(current) || '.';
  const prefix = path.basename(current);
  try {
    const fullDir = path.resolve(process.cwd(), dir);
    const files = fs.readdirSync(fullDir);
    const matches = files
      .filter((f) => f.startsWith(prefix))
      .map((f) => {
        const joined = path.join(dir === '.' ? '' : dir, f);
        try {
          const stat = fs.statSync(path.resolve(process.cwd(), joined));
          return stat.isDirectory() ? joined + path.sep : joined;
        } catch {
          return joined;
        }
      });
    return matches;
  } catch {
    return [];
  }
}

function isCompletingFileValue() {
  const argv = process.argv;
  const prev = argv[argv.length - 2];
  return typeof prev === 'string' && FILE_FLAGS.includes(prev);
}

yargs
  .option('ci', {
    type: 'boolean',
    description: 'Run in CI mode (minimal output, no colors)',
    default: isCI,
  })
  .option('no-color', {
    type: 'boolean',
    description: 'Disable colored output',
    default: false,
  })
  .middleware((argv) => {
    setOutputConfig({
      ci: argv.ci,
      color: !argv.noColor && !argv.ci && process.stdout.isTTY,
    });
  })
  .command(
    'create-stack',
    'Create a CloudFormation stack',
    (cmd) => {
      cmd
        .option('name', {
          type: 'string',
          alias: 'n',
          describe: 'Stack name',
          demandOption: true,
        })
        .option('template', {
          type: 'string',
          alias: 't',
          describe: 'CloudFormation template file',
          demandOption: true,
        })
        .option('params', {
          type: 'string',
          alias: 'p',
          describe: 'Parameters file (YAML)',
          demandOption: true,
        });
    },
    async ({ name, template, params }) => {
      log(`Creating stack: ${name}...`);
      try {
        await createStack(name, template, params);
      } catch (err) {
        errorLog(err.message);
        if (err.data) {
          log('\nError details:');
          log(JSON.stringify(err.data, null, 2));
        }
        process.exit(1);
      }
    }
  )
  .command(
    'delete-stack',
    'Delete a CloudFormation stack',
    (cmd) => {
      cmd
        .option('name', {
          type: 'string',
          alias: 'n',
          describe: 'Stack name',
          demandOption: true,
        })
        .option('confirm', {
          type: 'string',
          alias: 'c',
          describe: 'Repeat stack name to confirm deletion',
          demandOption: true,
        });
    },
    async ({ name, confirm }) => {
      log(`Deleting stack: ${name}...`);
      try {
        await deleteStack(name, confirm);
      } catch (err) {
        errorLog(err.message);
        process.exit(1);
      }
    }
  )
  .command(
    'redeploy-stack',
    'Redeploy a CloudFormation stack (uses existing params)',
    (cmd) => {
      cmd
        .option('name', {
          type: 'string',
          alias: 'n',
          describe: 'Stack name',
          demandOption: true,
        })
        .option('template', {
          type: 'string',
          alias: 't',
          describe: 'CloudFormation template file',
          demandOption: true,
        });
    },
    async ({ name, template }) => {
      log(`Redeploying stack: ${name}...`);
      try {
        await redeployStack(name, template);
      } catch (err) {
        errorLog(err.message);
        if (err.data) {
          log('\nError details:');
          log(JSON.stringify(err.data, null, 2));
        }
        process.exit(1);
      }
    }
  )
  .command(
    'update-stack',
    'Update a CloudFormation stack',
    (cmd) => {
      cmd
        .option('name', {
          type: 'string',
          alias: 'n',
          describe: 'Stack name',
          demandOption: true,
        })
        .option('template', {
          type: 'string',
          alias: 't',
          describe: 'CloudFormation template file',
          demandOption: true,
        })
        .option('params', {
          type: 'string',
          alias: 'p',
          describe: 'Parameters file (YAML)',
          demandOption: true,
        });
    },
    async ({ name, template, params }) => {
      log(`Updating stack: ${name}...`);
      try {
        await updateStack(name, template, params);
      } catch (err) {
        errorLog(err.message);
        if (err.data) {
          log('\nError details:');
          log(JSON.stringify(err.data, null, 2));
        }
        process.exit(1);
      }
    }
  )
  .completion(
    'completion',
    'Generate shell completion script',
    (current, argv, defaultCompletion, done) => {
      if (isCompletingFileValue()) {
        const matches = completeFile(current || '');
        return done(matches);
      }
      defaultCompletion();
    }
  )
  .demandCommand(1)
  .fail((msg, err, yargs) => {
    if (msg) {
      errorLog(msg);
      log('\n' + yargs.help());
    }
    process.exit(1);
  })
  .strict()
  .help()
  .alias('h', 'help')
  .version(version)
  .argv;
