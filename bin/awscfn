#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const yargs = require('yargs');

const { createStack } = require('../dist/createStack');
const { deleteStack } = require('../dist/deleteStack');
const { redeployStack } = require('../dist/redeployStack');
const { updateStack } = require('../dist/updateStack');
const { setOutputConfig } = require('../dist/lib/output');

const pkg = JSON.parse(fs.readFileSync(path.resolve(__dirname, '../package.json'), 'utf8'));
const isCI = process.env.CI === 'true' || process.env.GITHUB_ACTIONS === 'true';

const FILE_FLAGS = ['--template', '--params', '-t', '-p'];

function completeFile(current) {
  const dir = path.dirname(current) || '.';
  const prefix = path.basename(current);
  try {
    const fullDir = path.resolve(process.cwd(), dir);
    const files = fs.readdirSync(fullDir);
    return files
      .filter((f) => f.startsWith(prefix))
      .map((f) => {
        const joined = path.join(dir === '.' ? '' : dir, f);
        try {
          const stat = fs.statSync(path.resolve(process.cwd(), joined));
          return stat.isDirectory() ? joined + path.sep : joined;
        } catch {
          return joined;
        }
      });
  } catch {
    return [];
  }
}

function isCompletingFileValue() {
  const argv = process.argv;
  const prev = argv[argv.length - 2];
  return typeof prev === 'string' && FILE_FLAGS.includes(prev);
}

function logError(msg) {
  console.log(`\x1b[31mError: ${msg}\x1b[0m`);
}

function logErrorDetails(data) {
  if (data) {
    console.log('\nError details:');
    console.log(JSON.stringify(data, null, 2));
  }
}

async function runCommand(fn) {
  try {
    await fn();
  } catch (err) {
    logError(err.message);
    logErrorDetails(err.data);
    process.exit(1);
  }
}

const nameOpt = {
  name: { type: 'string', alias: 'n', describe: 'Stack name', demandOption: true },
};
const templateOpt = {
  template: { type: 'string', alias: 't', describe: 'CloudFormation template file', demandOption: true },
};
const paramsOpt = {
  params: { type: 'string', alias: 'p', describe: 'Parameters file (YAML)', demandOption: true },
};
const confirmOpt = {
  confirm: { type: 'string', alias: 'c', describe: 'Repeat stack name to confirm deletion', demandOption: true },
};

yargs
  .option('ci', {
    type: 'boolean',
    description: 'CI mode (compact output). Auto-detected when CI=true or GITHUB_ACTIONS=true. Colors remain enabled in CI.',
    default: isCI,
  })
  .option('no-color', {
    type: 'boolean',
    alias: 'N',
    description: 'Disable colored output',
    default: false,
  })
  .middleware((argv) => {
    setOutputConfig({
      ci: argv.ci,
      color: !argv.noColor && (process.stdout.isTTY || argv.ci),
    });
  })
  .command(
    'create-stack',
    'Create a CloudFormation stack',
    (cmd) => cmd.options({ ...nameOpt, ...templateOpt, ...paramsOpt }),
    ({ name, template, params }) => {
      console.log(`Creating stack: ${name}...`);
      runCommand(() => createStack(name, template, params));
    }
  )
  .command(
    'delete-stack',
    'Delete a CloudFormation stack',
    (cmd) => cmd.options({ ...nameOpt, ...confirmOpt }),
    ({ name, confirm }) => {
      console.log(`Deleting stack: ${name}...`);
      runCommand(() => deleteStack(name, confirm));
    }
  )
  .command(
    'redeploy-stack',
    'Redeploy a CloudFormation stack (uses existing params)',
    (cmd) => cmd.options({ ...nameOpt, ...templateOpt }),
    ({ name, template }) => {
      console.log(`Redeploying stack: ${name}...`);
      runCommand(() => redeployStack(name, template));
    }
  )
  .command(
    'update-stack',
    'Update a CloudFormation stack',
    (cmd) => cmd.options({ ...nameOpt, ...templateOpt, ...paramsOpt }),
    ({ name, template, params }) => {
      console.log(`Updating stack: ${name}...`);
      runCommand(() => updateStack(name, template, params));
    }
  )
  .completion(
    'completion',
    'Generate shell completion script',
    (current, argv, defaultCompletion, done) => {
      if (isCompletingFileValue()) {
        return done(completeFile(current || ''));
      }
      defaultCompletion();
    }
  )
  .demandCommand(1)
  .fail((msg, err, yargs) => {
    if (msg) {
      logError(msg);
      console.log('\n' + yargs.help());
    }
    process.exit(1);
  })
  .strict()
  .help()
  .alias('h', 'help')
  .version(pkg.version)
  .alias('v', 'version')
  .argv;
